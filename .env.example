# Database provider: "sqlite" (local file DB) or "supabase" (hosted).
# Resolution: this var wins; if unset and NEXT_PUBLIC_SUPABASE_URL is set the
# app stays on Supabase (existing deployments never silently switch to an
# empty local DB); otherwise it defaults to sqlite.
# NOTE: sqlite needs a persistent disk — it will not start on Vercel/serverless.
NEXT_PUBLIC_ASTRA_DB_PROVIDER=sqlite

# SQLite provider (default). Path is relative to the project root.
ASTRA_SQLITE_PATH=data/astra.db

# Public browser-safe values
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase provider — only required when NEXT_PUBLIC_ASTRA_DB_PROVIDER=supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=15000

# Optional E2E-only values. Do not commit real credentials.
ASTRA_TEST_EMAIL=
ASTRA_TEST_PASSWORD=
